generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())

  riotAccounts RiotAccount[]
}

model RiotRank {
  id            Int         @id @default(autoincrement())

  queueType     String
  tier          String
  rank          String
  leaguePoints  Int

  wins          Int
  losses        Int

  veteran       Boolean
  inactive      Boolean
  freshBlood    Boolean
  hotStreak     Boolean

  updatedAt     DateTime    @updatedAt

  riotAccountId Int
  riotAccount   RiotAccount @relation(fields: [riotAccountId], references: [id])

  @@unique([riotAccountId, queueType])
}

model RiotAccount {
  id                Int                @id @default(autoincrement())
  gameName          String
  tagLine           String
  puuid             String?            @unique
  region            String
  createdAt         DateTime           @default(now())
  login             String?
  passAccount       String?

  userId            Int
  user              User               @relation(fields: [userId], references: [id])

  ranks             RiotRank[]
  championMasteries ChampionMastery[]
  matches           Match[]

  @@unique([gameName, tagLine])
}

model Champion {
  id          Int                 @id
  riotKey     String              @unique
  name        String
  imageUrl    String
  version     String

  masteries   ChampionMastery[]
  matches     Match[]
}

model ChampionMastery {
  id                             Int         @id @default(autoincrement())

  championId                     Int
  champion                       Champion    @relation(fields: [championId], references: [id])

  championLevel                  Int
  championPoints                 Int
  championPointsSinceLastLevel   Int
  championPointsUntilNextLevel   Int
  markRequiredForNextLevel       Int
  tokensEarned                   Int
  lastPlayTime                   DateTime
  updatedAt                      DateTime    @updatedAt

  riotAccountId                  Int
  riotAccount                    RiotAccount @relation(fields: [riotAccountId], references: [id])

  @@unique([riotAccountId, championId])
}

model Match {
  id            Int         @id @default(autoincrement())

  matchId       String      @unique

  championId    Int
  champion      Champion    @relation(fields: [championId], references: [id])

  kills         Int
  deaths        Int
  assists       Int
  win           Boolean
  gameDuration  Int
  playedAt      DateTime

  riotAccountId Int
  riotAccount   RiotAccount @relation(fields: [riotAccountId], references: [id])
}